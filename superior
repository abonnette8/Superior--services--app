<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<title>Superior Services</title>
<link href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;500;600;700&family=Open+Sans:wght@400;500;600&display=swap" rel="stylesheet">
<style>
:root {
  --red:#cc1b1b; --red-dark:#a01515; --red-light:#e52222;
  --blue:#1a3a6b; --blue-mid:#1e4d9b; --blue-light:#2563c7;
  --white:#fff; --off-white:#f0f4ff; --silver:#dde3f0;
  --muted:#8896b3; --bg:#eef1f8; --surface:#fff;
  --border:#c8d0e4; --green:#16a34a; --radius:13px;
  --good:#16a34a; --caution:#d97706; --bad:#cc1b1b;
}
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent;}
body{background:var(--bg);color:var(--blue);font-family:'Open Sans',sans-serif;min-height:100vh;max-width:430px;margin:0 auto;padding-bottom:96px;}

/* HEADER */
.header{background:linear-gradient(160deg,var(–blue) 0%,#0e2550 100%);padding:48px 18px 0;position:sticky;top:0;z-index:100;box-shadow:0 3px 16px rgba(10,25,60,0.35);}
.header-brand{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;}
.logo-block{display:flex;flex-direction:column;}
.logo-main{font-family:‘Oswald’,sans-serif;font-size:26px;font-weight:700;color:#fff;letter-spacing:0.5px;line-height:1;}
.logo-main span{color:#ff6b6b;}
.logo-sub{font-family:‘Oswald’,sans-serif;font-size:11px;color:rgba(255,255,255,0.5);letter-spacing:2px;text-transform:uppercase;margin-top:2px;}
.logo-services{display:flex;gap:5px;margin-top:5px;}
.svc-tag{font-size:9px;font-weight:600;padding:2px 6px;border-radius:4px;text-transform:uppercase;letter-spacing:0.5px;}
.svc-hvac{background:rgba(204,27,27,0.3);color:#ffaaaa;border:1px solid rgba(204,27,27,0.5);}
.svc-elec{background:rgba(255,200,0,0.15);color:#ffd966;border:1px solid rgba(255,200,0,0.3);}
.svc-plumb{background:rgba(37,99,199,0.3);color:#90b8ff;border:1px solid rgba(37,99,199,0.5);}
.date-badge{font-size:11px;color:rgba(255,255,255,0.6);background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.15);padding:5px 11px;border-radius:20px;white-space:nowrap;}
.stripe{height:4px;background:linear-gradient(90deg,var(–red-dark),var(–red-light),var(–red-dark));}
.stats-row{display:grid;grid-template-columns:repeat(3,1fr);background:var(–blue);border-top:1px solid rgba(255,255,255,0.08);}
.stat{padding:10px 8px;text-align:center;border-right:1px solid rgba(255,255,255,0.1);}
.stat:last-child{border-right:none;}
.stat-num{font-family:‘Oswald’,sans-serif;font-size:26px;font-weight:700;line-height:1;}
.stat-num.s-new{color:#ff9090;}.stat-num.s-prog{color:#ffd966;}.stat-num.s-done{color:#6ee7a0;}
.stat-label{font-size:9px;color:rgba(255,255,255,0.45);margin-top:2px;text-transform:uppercase;letter-spacing:1px;}

/* NAV TABS */
.nav-tabs{display:flex;background:var(–blue);border-top:1px solid rgba(255,255,255,0.1);}
.nav-tab{flex:1;padding:10px 4px;text-align:center;font-family:‘Oswald’,sans-serif;font-size:12px;font-weight:600;color:rgba(255,255,255,0.5);letter-spacing:0.5px;cursor:pointer;border-bottom:3px solid transparent;transition:all 0.2s;}
.nav-tab.active{color:#fff;border-bottom-color:var(–red-light);}

/* FILTERS */
.filter-bar{padding:12px 16px 0;display:flex;gap:7px;overflow-x:auto;scrollbar-width:none;background:var(–bg);}
.filter-bar::-webkit-scrollbar{display:none;}
.filter-tab{flex-shrink:0;padding:6px 14px;border-radius:20px;font-size:12px;font-weight:600;border:1.5px solid var(–border);background:var(–white);color:var(–muted);cursor:pointer;transition:all 0.2s;}
.filter-tab.active{background:var(–blue);border-color:var(–blue);color:white;}
.section-title{padding:14px 16px 6px;font-family:‘Oswald’,sans-serif;font-size:12px;font-weight:600;letter-spacing:2px;text-transform:uppercase;color:var(–muted);}

/* PAGES */
.page{display:none;}.page.active{display:block;}

/* JOB CARDS */
.jobs-list{padding:0 16px;display:flex;flex-direction:column;gap:10px;}
.job-card{background:var(–surface);border-radius:var(–radius);border:1.5px solid var(–border);padding:13px;transition:all 0.2s;position:relative;overflow:hidden;animation:slideIn 0.3s ease;box-shadow:0 2px 8px rgba(20,40,100,0.07);}
@keyframes slideIn{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}
.job-card:active{transform:scale(0.985);}
.job-card::before{content:’’;position:absolute;left:0;top:0;bottom:0;width:4px;}
.job-card.new::before{background:var(–blue-light);}
.job-card.in-progress::before{background:#d97706;}
.job-card.done::before{background:var(–green);}
.job-top{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:7px;}
.job-name{font-family:‘Oswald’,sans-serif;font-size:18px;font-weight:600;color:var(–blue);line-height:1.1;flex:1;padding-right:8px;}
.status-pill{font-size:10px;font-weight:700;padding:3px 9px;border-radius:20px;text-transform:uppercase;letter-spacing:0.5px;white-space:nowrap;flex-shrink:0;font-family:‘Oswald’,sans-serif;}
.status-pill.new{background:rgba(37,99,199,0.1);color:var(–blue-light);border:1px solid rgba(37,99,199,0.2);}
.status-pill.in-progress{background:rgba(217,119,6,0.1);color:#d97706;border:1px solid rgba(217,119,6,0.25);}
.status-pill.done{background:rgba(22,163,74,0.1);color:var(–green);border:1px solid rgba(22,163,74,0.2);}
.job-meta{display:flex;flex-wrap:wrap;gap:5px;margin-bottom:9px;}
.meta-tag{font-size:11px;color:var(–muted);display:flex;align-items:center;gap:3px;}
.type-badge{font-size:10px;font-weight:700;padding:2px 8px;border-radius:5px;text-transform:uppercase;letter-spacing:0.5px;font-family:‘Oswald’,sans-serif;}
.type-hvac{background:rgba(204,27,27,0.1);color:var(–red);border:1px solid rgba(204,27,27,0.2);}
.type-electrical{background:rgba(180,83,9,0.1);color:#b45309;border:1px solid rgba(180,83,9,0.2);}
.type-plumbing{background:rgba(37,99,199,0.1);color:var(–blue-light);border:1px solid rgba(37,99,199,0.2);}
.type-construction{background:rgba(75,85,99,0.1);color:#4b5563;border:1px solid rgba(75,85,99,0.2);}
.job-notes{font-size:12px;color:#64748b;line-height:1.4;margin-bottom:8px;padding:6px 8px;background:var(–off-white);border-radius:7px;border-left:3px solid var(–silver);}
.photo-strip{display:flex;gap:6px;overflow-x:auto;scrollbar-width:none;margin-bottom:8px;}
.photo-strip::-webkit-scrollbar{display:none;}
.photo-thumb{width:60px;height:60px;border-radius:8px;object-fit:cover;flex-shrink:0;border:2px solid var(–border);cursor:pointer;}
.photo-count{font-size:11px;color:var(–muted);margin-bottom:4px;}
.job-actions{display:flex;gap:7px;padding-top:9px;border-top:1px solid var(–border);}
.action-btn{flex:1;padding:7px;border-radius:8px;border:1.5px solid var(–border);background:var(–off-white);color:var(–muted);font-size:12px;font-weight:600;cursor:pointer;text-align:center;transition:all 0.2s;}
.action-btn:active{transform:scale(0.96);}
.action-btn.advance{background:var(–blue);border-color:var(–blue);color:white;}
.action-btn.edit-btn{background:rgba(37,99,199,0.08);border-color:rgba(37,99,199,0.25);color:var(–blue-light);}
.action-btn.done-btn{background:rgba(22,163,74,0.08);border-color:rgba(22,163,74,0.25);color:var(–green);}
.action-btn.delete{background:rgba(204,27,27,0.06);border-color:rgba(204,27,27,0.2);color:var(–red);flex:0;padding:7px 13px;}
.action-btn.checklist-btn{background:rgba(204,27,27,0.08);border-color:rgba(204,27,27,0.25);color:var(–red);}

/* EMPTY */
.empty-state{text-align:center;padding:56px 20px;}
.empty-icon{font-size:52px;margin-bottom:12px;}
.empty-title{font-family:‘Oswald’,sans-serif;font-size:22px;font-weight:600;margin-bottom:6px;color:var(–blue);}
.empty-sub{font-size:13px;line-height:1.6;color:var(–muted);}

/* FAB */
.fab{position:fixed;bottom:20px;left:50%;transform:translateX(-50%);width:calc(100% - 32px);max-width:398px;background:linear-gradient(135deg,var(–red-light),var(–red-dark));color:white;border:none;border-radius:14px;padding:16px;font-family:‘Oswald’,sans-serif;font-size:18px;font-weight:700;letter-spacing:1.5px;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:8px;box-shadow:0 4px 20px rgba(204,27,27,0.45);transition:all 0.2s;z-index:200;}
.fab:active{transform:translateX(-50%) scale(0.97);}

/* OVERLAY / MODAL */
.overlay{position:fixed;inset:0;background:rgba(10,25,60,0.65);backdrop-filter:blur(5px);z-index:300;display:none;align-items:flex-end;justify-content:center;}
.overlay.open{display:flex;}
.modal{background:var(–white);border-radius:22px 22px 0 0;width:100%;max-width:430px;animation:slideUp 0.3s ease;overflow:hidden;max-height:92vh;display:flex;flex-direction:column;}
@keyframes slideUp{from{transform:translateY(100%)}to{transform:translateY(0)}}
.modal-header{background:linear-gradient(135deg,var(–blue) 0%,#0e2550 100%);padding:16px 20px 18px;flex-shrink:0;}
.modal-handle{width:36px;height:4px;background:rgba(255,255,255,0.25);border-radius:2px;margin:0 auto 14px;}
.modal-stripe{height:3px;background:linear-gradient(90deg,var(–red-dark),var(–red-light),var(–red-dark));flex-shrink:0;}
.modal-title{font-family:‘Oswald’,sans-serif;font-size:22px;font-weight:700;color:white;}
.modal-sub{font-size:11px;color:rgba(255,255,255,0.5);margin-top:2px;}
.modal-body{padding:18px 20px 0;overflow-y:auto;flex:1;}
.form-group{margin-bottom:13px;}
.form-label{display:block;font-size:11px;font-weight:600;color:var(–muted);text-transform:uppercase;letter-spacing:1px;margin-bottom:5px;font-family:‘Oswald’,sans-serif;}
.form-input,.form-select{width:100%;background:var(–off-white);border:1.5px solid var(–border);border-radius:10px;padding:11px 13px;color:var(–blue);font-family:‘Open Sans’,sans-serif;font-size:15px;outline:none;transition:border-color 0.2s;-webkit-appearance:none;appearance:none;}
.form-input:focus,.form-select:focus{border-color:var(–blue-light);background:white;}
.form-input::placeholder{color:var(–muted);}
.type-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:8px;}
.type-option{padding:10px 8px;border-radius:10px;border:1.5px solid var(–border);background:var(–off-white);color:var(–muted);font-size:13px;font-weight:600;cursor:pointer;text-align:center;transition:all 0.2s;}
.type-option.selected{border-color:var(–blue);color:var(–blue);background:rgba(26,58,107,0.08);}
.photo-upload-area{border:2px dashed var(–border);border-radius:12px;padding:18px;text-align:center;cursor:pointer;background:var(–off-white);}
.photo-upload-icon{font-size:30px;margin-bottom:4px;}
.photo-upload-text{font-size:13px;color:var(–muted);font-weight:600;}
.photo-upload-sub{font-size:11px;color:var(–muted);margin-top:2px;}
#photoFileInput{display:none;}
.modal-photos-preview{display:flex;flex-wrap:wrap;gap:8px;margin-top:10px;}
.modal-photo-wrap{position:relative;width:72px;height:72px;}
.modal-photo-img{width:72px;height:72px;border-radius:8px;object-fit:cover;border:2px solid var(–border);}
.modal-photo-del{position:absolute;top:-6px;right:-6px;background:var(–red);color:white;border:none;border-radius:50%;width:20px;height:20px;font-size:11px;cursor:pointer;display:flex;align-items:center;justify-content:center;}
.notes-input{resize:none;height:68px;line-height:1.4;}
.modal-actions{display:flex;gap:10px;padding:14px 20px;flex-shrink:0;}
.btn-cancel{flex:1;padding:14px;border-radius:12px;border:1.5px solid var(–border);background:var(–off-white);color:var(–muted);font-size:15px;font-weight:600;cursor:pointer;}
.btn-save{flex:2;padding:14px;border-radius:12px;border:none;background:linear-gradient(135deg,var(–red-light),var(–red-dark));color:white;font-family:‘Oswald’,sans-serif;font-size:18px;font-weight:700;letter-spacing:1px;cursor:pointer;box-shadow:0 3px 12px rgba(204,27,27,0.3);transition:all 0.2s;}
.btn-save:active{transform:scale(0.97);}

/* ── CHECKLIST OVERLAY ── */
.cl-overlay{position:fixed;inset:0;background:var(–bg);z-index:400;display:none;flex-direction:column;overflow:hidden;}
.cl-overlay.open{display:flex;}
.cl-header{background:linear-gradient(135deg,var(–blue),#0e2550);padding:48px 16px 0;flex-shrink:0;}
.cl-header-top{display:flex;align-items:center;gap:12px;margin-bottom:12px;}
.cl-back{background:rgba(255,255,255,0.15);border:none;color:white;width:36px;height:36px;border-radius:50%;font-size:18px;cursor:pointer;display:flex;align-items:center;justify-content:center;}
.cl-title{font-family:‘Oswald’,sans-serif;font-size:20px;font-weight:700;color:white;flex:1;}
.cl-share-btn{background:rgba(255,255,255,0.15);border:none;color:white;padding:7px 12px;border-radius:20px;font-size:12px;font-weight:600;cursor:pointer;font-family:‘Oswald’,sans-serif;}
.cl-stripe{height:3px;background:linear-gradient(90deg,var(–red-dark),var(–red-light),var(–red-dark));}
.cl-info{display:grid;grid-template-columns:1fr 1fr;gap:6px;padding:10px 16px;background:rgba(255,255,255,0.05);}
.cl-info-item{font-size:11px;color:rgba(255,255,255,0.6);}
.cl-info-item span{color:white;font-weight:600;}
.cl-body{flex:1;overflow-y:auto;padding:12px 16px 20px;}

/* LEGEND */
.cl-legend{display:flex;gap:8px;margin-bottom:14px;padding:10px 12px;background:var(–surface);border-radius:10px;border:1px solid var(–border);}
.legend-item{display:flex;align-items:center;gap:5px;font-size:11px;font-weight:600;color:var(–blue);}
.legend-dot{width:14px;height:14px;border-radius:50%;flex-shrink:0;}
.legend-dot.good{background:var(–good);}
.legend-dot.caution{background:var(–caution);}
.legend-dot.bad{background:var(–bad);}

/* CHECKLIST SECTION */
.cl-section{background:var(–surface);border-radius:var(–radius);border:1.5px solid var(–border);margin-bottom:12px;overflow:hidden;box-shadow:0 2px 6px rgba(20,40,100,0.06);}
.cl-section-header{background:var(–blue);padding:10px 14px;font-family:‘Oswald’,sans-serif;font-size:14px;font-weight:600;color:white;letter-spacing:0.5px;}
.cl-item{display:flex;align-items:center;padding:11px 14px;border-bottom:1px solid var(–border);gap:10px;}
.cl-item:last-child{border-bottom:none;}
.cl-item-name{flex:1;font-size:13px;color:var(–blue);font-weight:600;line-height:1.2;}
.cl-btns{display:flex;gap:6px;flex-shrink:0;}

/* BIG COLORED BUTTONS - easy to tap in the field */
.cl-btn{
width:52px;height:44px;border-radius:10px;border:2px solid var(–border);
background:var(–off-white);cursor:pointer;font-size:11px;font-weight:800;
color:var(–muted);transition:all 0.15s;display:flex;flex-direction:column;
align-items:center;justify-content:center;gap:1px;letter-spacing:0.3px;
text-transform:uppercase;line-height:1;
}
.cl-btn:active{transform:scale(0.92);}
.cl-btn .btn-icon{font-size:15px;line-height:1;}
.cl-btn .btn-lbl{font-size:8px;font-weight:700;letter-spacing:0.5px;}

/* UNSELECTED TINTED */
.cl-btn.good-idle{border-color:rgba(22,163,74,0.3);background:rgba(22,163,74,0.06);color:rgba(22,163,74,0.5);}
.cl-btn.caution-idle{border-color:rgba(217,119,6,0.3);background:rgba(217,119,6,0.06);color:rgba(217,119,6,0.5);}
.cl-btn.bad-idle{border-color:rgba(204,27,27,0.3);background:rgba(204,27,27,0.06);color:rgba(204,27,27,0.5);}
.cl-btn.na-idle{border-color:rgba(37,99,199,0.3);background:rgba(37,99,199,0.06);color:rgba(37,99,199,0.5);}

/* SELECTED - full color */
.cl-btn.sel-good{background:#16a34a;border-color:#16a34a;color:white;box-shadow:0 3px 10px rgba(22,163,74,0.4);}
.cl-btn.sel-caution{background:#d97706;border-color:#d97706;color:white;box-shadow:0 3px 10px rgba(217,119,6,0.4);}
.cl-btn.sel-bad{background:#cc1b1b;border-color:#cc1b1b;color:white;box-shadow:0 3px 10px rgba(204,27,27,0.4);}
.cl-btn.sel-na{background:#2563c7;border-color:#2563c7;color:white;box-shadow:0 3px 10px rgba(37,99,199,0.4);}

/* CHECKLIST EXTRAS */
.cl-extras{background:var(–surface);border-radius:var(–radius);border:1.5px solid var(–border);padding:14px;margin-bottom:12px;}
.cl-extras-title{font-family:‘Oswald’,sans-serif;font-size:14px;font-weight:600;color:var(–blue);margin-bottom:12px;letter-spacing:0.5px;}
.cl-row{display:flex;gap:10px;margin-bottom:10px;}
.cl-field{flex:1;}
.cl-field label{display:block;font-size:10px;font-weight:600;color:var(–muted);text-transform:uppercase;letter-spacing:0.8px;margin-bottom:4px;}
.cl-input{width:100%;background:var(–off-white);border:1.5px solid var(–border);border-radius:8px;padding:9px 11px;color:var(–blue);font-family:‘Open Sans’,sans-serif;font-size:14px;outline:none;}
.cl-input:focus{border-color:var(–blue-light);}
.cl-toggle-row{display:flex;gap:8px;}
.cl-toggle{flex:1;padding:9px 6px;border-radius:8px;border:1.5px solid var(–border);background:var(–off-white);color:var(–muted);font-size:12px;font-weight:600;cursor:pointer;text-align:center;transition:all 0.2s;}
.cl-toggle.sel{background:var(–blue);border-color:var(–blue);color:white;}
.cl-textarea{width:100%;background:var(–off-white);border:1.5px solid var(–border);border-radius:8px;padding:9px 11px;color:var(–blue);font-family:‘Open Sans’,sans-serif;font-size:14px;outline:none;resize:none;height:80px;line-height:1.4;}
.cl-textarea:focus{border-color:var(–blue-light);}

/* CL PHOTOS */
.cl-photo-upload{border:2px dashed var(–border);border-radius:10px;padding:16px;text-align:center;cursor:pointer;background:var(–off-white);margin-bottom:10px;}
.cl-photos-preview{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:10px;}
.cl-photo-wrap{position:relative;width:80px;height:80px;}
.cl-photo-img{width:80px;height:80px;border-radius:8px;object-fit:cover;border:2px solid var(–border);cursor:pointer;}
.cl-photo-del{position:absolute;top:-6px;right:-6px;background:var(–red);color:white;border:none;border-radius:50%;width:20px;height:20px;font-size:11px;cursor:pointer;display:flex;align-items:center;justify-content:center;}

/* CL SUMMARY BADGE */
.cl-summary{display:flex;gap:6px;padding:8px 12px;background:var(–off-white);border-radius:8px;border:1px solid var(–border);margin-bottom:10px;}
.cl-sum-item{flex:1;text-align:center;}
.cl-sum-num{font-family:‘Oswald’,sans-serif;font-size:18px;font-weight:700;}
.cl-sum-num.g{color:var(–good);}.cl-sum-num.c{color:var(–caution);}.cl-sum-num.b{color:var(–bad);}
.cl-sum-lbl{font-size:9px;color:var(–muted);text-transform:uppercase;letter-spacing:0.5px;}

.cl-save-btn{width:100%;padding:16px;border-radius:14px;border:none;background:linear-gradient(135deg,var(–red-light),var(–red-dark));color:white;font-family:‘Oswald’,sans-serif;font-size:18px;font-weight:700;letter-spacing:1px;cursor:pointer;box-shadow:0 4px 16px rgba(204,27,27,0.35);margin-top:4px;}

/* LIGHTBOX */
.lightbox{position:fixed;inset:0;background:rgba(0,0,0,0.92);z-index:600;display:none;align-items:center;justify-content:center;flex-direction:column;}
.lightbox.open{display:flex;}
.lightbox img{max-width:95vw;max-height:80vh;border-radius:10px;object-fit:contain;}
.lightbox-close{position:absolute;top:20px;right:20px;background:rgba(255,255,255,0.15);border:none;color:white;font-size:24px;width:44px;height:44px;border-radius:50%;cursor:pointer;}
.lightbox-nav{display:flex;gap:16px;margin-top:16px;}
.lightbox-btn{background:rgba(255,255,255,0.15);border:none;color:white;font-size:20px;width:44px;height:44px;border-radius:50%;cursor:pointer;}
.lightbox-counter{color:rgba(255,255,255,0.6);font-size:13px;margin-top:8px;}

/* SHARE MODAL */
.share-overlay{position:fixed;inset:0;background:rgba(10,25,60,0.7);z-index:700;display:none;align-items:flex-end;justify-content:center;}
.share-overlay.open{display:flex;}
.share-modal{background:white;border-radius:22px 22px 0 0;width:100%;max-width:430px;padding:24px 20px 40px;animation:slideUp 0.3s ease;}
.share-title{font-family:‘Oswald’,sans-serif;font-size:20px;font-weight:700;color:var(–blue);margin-bottom:4px;}
.share-sub{font-size:12px;color:var(–muted);margin-bottom:16px;}
.share-text{background:var(–off-white);border:1.5px solid var(–border);border-radius:10px;padding:12px;font-size:12px;color:var(–blue);line-height:1.6;white-space:pre-wrap;max-height:260px;overflow-y:auto;margin-bottom:14px;}
.share-btns{display:flex;gap:10px;}
.share-copy-btn{flex:1;padding:14px;border-radius:12px;border:none;background:var(–blue);color:white;font-family:‘Oswald’,sans-serif;font-size:16px;font-weight:700;cursor:pointer;}
.share-close-btn{flex:0;padding:14px 18px;border-radius:12px;border:1.5px solid var(–border);background:var(–off-white);color:var(–muted);font-size:15px;font-weight:600;cursor:pointer;}

.phone-footer{text-align:center;padding:10px 0 4px;font-family:‘Oswald’,sans-serif;font-size:13px;color:var(–muted);}
.phone-footer span{color:var(–red);font-weight:600;}

</style>
