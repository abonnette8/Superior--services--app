<script>
// ── DATA ──
let jobs       = JSON.parse(localStorage.getItem('superior_jobs')  || '[]');
let hvacReports= JSON.parse(localStorage.getItem('superior_hvac')  || '[]');
let activeFilter='all', activePage='jobs';
let selectedType='', editingJobId=null, pendingPhotos=[];
let lightboxPhotos=[], lightboxIndex=0;
let currentReportId=null;

// checklist items
const CL_SECTIONS = [
  { title:'Unit Type', items:['Multi units','Single units','Complete system','Inside unit','Outside unit'] },
  { title:'Capacitors', items:['5 uf capacitors','7.7 cap','10 uf cap','30 + 5 cap','35 + 5 cap','45 + 5 cap','40 + 5 cap','50 + 5 cap','55 + 5 cap','80 + 5 cap','Hard start cap'] },
  { title:'Electrical / Fuses', items:['30 amp fuses','60 amp fuses','Transformers','24v contactors'] },
  { title:'Refrigerant', items:['R-22','410A','Leak check','Leak sealant/dye'] },
  { title:'Thermostats', items:['Straight cool t stats','Heat pump t stats'] },
  { title:'Switches / Float', items:['Pan float switch','Inline float switch'] },
  { title:'Coil / Drain', items:['Pull evap and clean','Clean evap in place','Drain pan'] },
  { title:'Ductwork / Other', items:['Strap up ducts','Motor','Seal air leaks','Toilet flapper','Flow valve'] }
];

function saveJobs()   {
  try { localStorage.setItem('superior_jobs', JSON.stringify(jobs)); }
  catch(e) { alert('Storage full — try removing some photos from jobs and try again.'); }
}
function saveHvac()   {
  try { localStorage.setItem('superior_hvac', JSON.stringify(hvacReports)); }
  catch(e) { alert('Storage full — try removing some photos from reports and try again.'); }
}

document.getElementById('dateLabel').textContent =
  new Date().toLocaleDateString('en-US',{weekday:'short',month:'short',day:'numeric'});

// ── PAGE NAV ──
document.querySelectorAll('.nav-tab').forEach(tab => {
  tab.addEventListener('click', () => {
    document.querySelectorAll('.nav-tab').forEach(t=>t.classList.remove('active'));
    tab.classList.add('active');
    activePage = tab.dataset.page;
    document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
    document.getElementById('page-'+activePage).classList.add('active');
    document.getElementById('fabLabel').textContent = activePage==='jobs' ? 'ADD NEW JOB' : 'NEW HVAC REPORT';
    if(activePage==='hvac') renderHvacList();
  });
});

// ── RENDER JOBS ──
const typeClass={HVAC:'type-hvac',Electrical:'type-electrical',Plumbing:'type-plumbing',Construction:'type-construction'};
const sLabel={new:'New','in-progress':'In Progress',done:'Done'};
const sNext={new:'in-progress','in-progress':'done',done:null};
const sBtn={new:'▶ Start','in-progress':'✓ Done'};

function renderJobs() {
  const filtered = activeFilter==='all' ? jobs : jobs.filter(j=>j.status===activeFilter);
  document.getElementById('statNew').textContent      = jobs.filter(j=>j.status==='new').length;
  document.getElementById('statProgress').textContent = jobs.filter(j=>j.status==='in-progress').length;
  document.getElementById('statDone').textContent     = jobs.filter(j=>j.status==='done').length;
  const labels={all:'ALL JOBS',new:'NEW JOBS','in-progress':'IN PROGRESS',done:'COMPLETED'};
  document.getElementById('sectionLabel').textContent=`${labels[activeFilter]} (${filtered.length})`;
  const list=document.getElementById('jobsList');
  if(!filtered.length){list.innerHTML=`<div class="empty-state"><div class="empty-icon">🔧</div><div class="empty-title">No jobs yet</div><div class="empty-sub">Tap Add New Job below.</div></div>`;return;}
  list.innerHTML=filtered.slice().reverse().map(job=>{
    const photos=job.photos||[];
    const photoHTML=photos.length?`<div class="photo-count">📷 ${photos.length} photo${photos.length>1?'s':''}</div><div class="photo-strip">${photos.map((p,i)=>`<img class="photo-thumb" src="${p}" onclick="openLightbox('job','${job.id}',${i})">`).join('')}</div>`:'';
    const nxt=sNext[job.status];
    return `<div class="job-card ${job.status}">
      <div class="job-top"><div class="job-name">${job.name}</div><div class="status-pill ${job.status}">${sLabel[job.status]}</div></div>
      <div class="job-meta">
        <span class="type-badge ${typeClass[job.type]||'type-hvac'}">${job.type}</span>
        <span class="meta-tag">📋 ${job.category}</span>
        ${job.address?`<span class="meta-tag">📍 ${job.address}</span>`:''}
        ${job.phone?`<span class="meta-tag">📞 ${job.phone}</span>`:''}
      </div>
      ${job.notes?`<div class="job-notes">${job.notes}</div>`:''}
      ${photoHTML}
      <div class="job-actions">
        <button class="action-btn edit-btn" onclick="openEditJob('${job.id}')">✏️ Edit</button>
        ${nxt?`<button class="action-btn advance" onclick="advanceJob('${job.id}')">${sBtn[job.status]}</button>`:`<div class="action-btn done-btn">✓ Done</div>`}
        <button class="action-btn delete" onclick="deleteJob('${job.id}')">🗑</button>
      </div>
    </div>`;
  }).join('');
}

function advanceJob(id){const j=jobs.find(j=>j.id===id);if(j&&sNext[j.status]){j.status=sNext[j.status];saveJobs();renderJobs();}}
function deleteJob(id){if(confirm('Delete this job?')){jobs=jobs.filter(j=>j.id!==id);saveJobs();renderJobs();}}

document.querySelectorAll('.filter-tab').forEach(btn=>{
  btn.addEventListener('click',()=>{
    document.querySelectorAll('.filter-tab').forEach(b=>b.classList.remove('active'));
    btn.classList.add('active');activeFilter=btn.dataset.filter;renderJobs();
  });
});

// ── RENDER HVAC LIST ──
function renderHvacList(){
  const list=document.getElementById('hvacList');
  if(!hvacReports.length){list.innerHTML=`<div class="empty-state"><div class="empty-icon">🌡️</div><div class="empty-title">No reports yet</div><div class="empty-sub">Tap New HVAC Report below.</div></div>`;return;}
  list.innerHTML=hvacReports.slice().reverse().map(r=>{
    const good=Object.values(r.checks||{}).filter(v=>v==='good').length;
    const caution=Object.values(r.checks||{}).filter(v=>v==='caution').length;
    const bad=Object.values(r.checks||{}).filter(v=>v==='bad').length;
    const photos=(r.photos||[]).length;
    return `<div class="job-card new" style="cursor:pointer;" onclick="openReport('${r.id}')">
      <div class="job-top">
        <div class="job-name">${r.customer||'Unnamed'}</div>
        <div class="status-pill new">${r.date||'—'}</div>
      </div>
      <div class="job-meta">
        <span class="meta-tag">📍 ${r.address||'No address'}</span>
        ${r.unit?`<span class="meta-tag">🔢 Unit #${r.unit}</span>`:''}
        ${r.tonnage?`<span class="meta-tag">⚖️ ${r.tonnage} ton</span>`:''}
      </div>
      <div class="cl-summary" style="margin-bottom:8px;">
        <div class="cl-sum-item"><div class="cl-sum-num g">${good}</div><div class="cl-sum-lbl">Good</div></div>
        <div class="cl-sum-item"><div class="cl-sum-num c">${caution}</div><div class="cl-sum-lbl">Caution</div></div>
        <div class="cl-sum-item"><div class="cl-sum-num b">${bad}</div><div class="cl-sum-lbl">Bad</div></div>
        ${photos?`<div class="cl-sum-item"><div class="cl-sum-num" style="color:var(--blue-light);">${photos}</div><div class="cl-sum-lbl">Photos</div></div>`:''}
      </div>
      <div class="job-actions">
        <button class="action-btn edit-btn" onclick="event.stopPropagation();openReport('${r.id}')">✏️ Open / Edit</button>
        <button class="action-btn delete" onclick="event.stopPropagation();deleteReport('${r.id}')">🗑</button>
      </div>
    </div>`;
  }).join('');
}

function deleteReport(id){if(confirm('Delete this report?')){hvacReports=hvacReports.filter(r=>r.id!==id);saveHvac();renderHvacList();}}

// ── FAB ──
document.getElementById('fabBtn').addEventListener('click',()=>{
  if(activePage==='jobs') openNewJob();
  else openNewReport();
});

// ── JOB MODAL ──
const overlay=document.getElementById('overlay');
function openNewJob(){
  editingJobId=null;selectedType='';pendingPhotos=[];
  document.getElementById('modalTitle').textContent='New Job';
  ['inputName','inputAddress','inputPhone','inputNotes'].forEach(id=>document.getElementById(id).value='');
  document.getElementById('inputStatus').value='new';
  document.getElementById('inputCategory').value='Service Call';
  document.querySelectorAll('.type-option').forEach(o=>o.classList.remove('selected'));
  renderModalPhotos();overlay.classList.add('open');
  setTimeout(()=>document.getElementById('inputName').focus(),350);
}
function openEditJob(id){
  const job=jobs.find(j=>j.id===id);if(!job)return;
  editingJobId=id;selectedType=job.type;pendingPhotos=job.photos?[...job.photos]:[];
  document.getElementById('modalTitle').textContent='Edit Job';
  document.getElementById('inputName').value=job.name;
  document.getElementById('inputAddress').value=job.address||'';
  document.getElementById('inputPhone').value=job.phone||'';
  document.getElementById('inputNotes').value=job.notes||'';
  document.getElementById('inputStatus').value=job.status;
  document.getElementById('inputCategory').value=job.category;
  document.querySelectorAll('.type-option').forEach(o=>o.classList.toggle('selected',o.dataset.type===job.type));
  renderModalPhotos();overlay.classList.add('open');
}
document.getElementById('cancelBtn').addEventListener('click',()=>overlay.classList.remove('open'));
overlay.addEventListener('click',e=>{if(e.target===overlay)overlay.classList.remove('open');});
document.querySelectorAll('.type-option').forEach(opt=>{
  opt.addEventListener('click',()=>{document.querySelectorAll('.type-option').forEach(o=>o.classList.remove('selected'));opt.classList.add('selected');selectedType=opt.dataset.type;});
});
// ── PHOTO COMPRESSION ──
function compressPhoto(file, callback) {
  const reader = new FileReader();
  reader.onload = e => {
    const img = new Image();
    img.onload = () => {
      const canvas = document.createElement('canvas');
      const MAX = 800; // max width or height in px
      let w = img.width, h = img.height;
      if (w > h) { if (w > MAX) { h = h * MAX / w; w = MAX; } }
      else        { if (h > MAX) { w = w * MAX / h; h = MAX; } }
      canvas.width = w; canvas.height = h;
      canvas.getContext('2d').drawImage(img, 0, 0, w, h);
      callback(canvas.toDataURL('image/jpeg', 0.6)); // 60% quality JPEG
    };
    img.src = e.target.result;
  };
  reader.readAsDataURL(file);
}

document.getElementById('photoUploadArea').addEventListener('click',()=>document.getElementById('photoFileInput').click());
document.getElementById('photoFileInput').addEventListener('change',function(){
  Array.from(this.files).forEach(f=>{
    compressPhoto(f, compressed => { pendingPhotos.push(compressed); renderModalPhotos(); });
  });
  this.value='';
});
function renderModalPhotos(){
  const p=document.getElementById('modalPhotosPreview');
  p.innerHTML=pendingPhotos.map((ph,i)=>`<div class="modal-photo-wrap"><img class="modal-photo-img" src="${ph}"><button class="modal-photo-del" onclick="removeModalPhoto(${i})">✕</button></div>`).join('');
}
function removeModalPhoto(i){pendingPhotos.splice(i,1);renderModalPhotos();}
document.getElementById('saveBtn').addEventListener('click',()=>{
  const name=document.getElementById('inputName').value.trim();
  if(!name){alert('Please enter a customer name.');return;}
  if(!selectedType){alert('Please select a trade type.');return;}
  const data={name,address:document.getElementById('inputAddress').value.trim(),phone:document.getElementById('inputPhone').value.trim(),type:selectedType,category:document.getElementById('inputCategory').value,status:document.getElementById('inputStatus').value,notes:document.getElementById('inputNotes').value.trim(),photos:[...pendingPhotos]};
  if(editingJobId){const j=jobs.find(j=>j.id===editingJobId);if(j)Object.assign(j,data);}
  else{jobs.push({id:Date.now().toString(),...data,createdAt:new Date().toISOString()});}
  saveJobs();overlay.classList.remove('open');
  activeFilter='all';document.querySelectorAll('.filter-tab').forEach(b=>b.classList.remove('active'));
  document.querySelector('[data-filter="all"]').classList.add('active');renderJobs();
});

// ── HVAC CHECKLIST ──
let clReport = {};

function openNewReport(){
  clReport={id:Date.now().toString(),customer:'',address:'',unit:'',tech:'',date:new Date().toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'}),tonnage:'',fuel:'',filter:'',notes:'',checks:{},photos:[]};
  currentReportId=null;
  renderChecklist();
  document.getElementById('clOverlay').classList.add('open');
}
function openReport(id){
  const r=hvacReports.find(r=>r.id===id);if(!r)return;
  clReport=JSON.parse(JSON.stringify(r));
  currentReportId=id;
  renderChecklist();
  document.getElementById('clOverlay').classList.add('open');
}
document.getElementById('clBack').addEventListener('click',()=>{
  document.getElementById('clOverlay').classList.remove('open');
  renderHvacList();
});

function renderChecklist(){
  document.getElementById('clTitle').textContent='HVAC Maintenance';
  document.getElementById('clCustomer').textContent=clReport.customer||'—';
  document.getElementById('clDate').textContent=clReport.date||'—';
  document.getElementById('clAddr').textContent=clReport.address||'—';
  document.getElementById('clTech').textContent=clReport.tech||'—';

  const good=Object.values(clReport.checks||{}).filter(v=>v==='good').length;
  const caution=Object.values(clReport.checks||{}).filter(v=>v==='caution').length;
  const bad=Object.values(clReport.checks||{}).filter(v=>v==='bad').length;

  let html=`
  <div class="cl-legend">
    <div class="legend-item"><div class="legend-dot good"></div>Good</div>
    <div class="legend-item"><div class="legend-dot caution"></div>Caution</div>
    <div class="legend-item"><div class="legend-dot bad"></div>Bad</div>
