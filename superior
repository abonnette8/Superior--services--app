    <div class="cl-sum-item"><div class="cl-sum-num c">${caution}</div><div class="cl-sum-lbl">Caution</div></div>
    <div class="cl-sum-item"><div class="cl-sum-num b">${bad}</div><div class="cl-sum-lbl">Issues</div></div>
  </div>

  <!-- JOB INFO -->
  <div class="cl-extras">
    <div class="cl-extras-title">Job Info</div>
    <div class="cl-row">
      <div class="cl-field"><label>Customer Name</label><input class="cl-input" id="cl_customer" value="${clReport.customer||''}" placeholder="John Smith" oninput="clReport.customer=this.value;updateClHeader();"></div>
    </div>
    <div class="cl-row">
      <div class="cl-field"><label>Address</label><input class="cl-input" id="cl_address" value="${clReport.address||''}" placeholder="123 Main St" oninput="clReport.address=this.value;updateClHeader();"></div>
      <div class="cl-field" style="max-width:90px;"><label>Unit #</label><input class="cl-input" id="cl_unit" value="${clReport.unit||''}" placeholder="A1" oninput="clReport.unit=this.value;"></div>
    </div>
    <div class="cl-row">
      <div class="cl-field"><label>Technician</label><input class="cl-input" id="cl_tech" value="${clReport.tech||''}" placeholder="Tech name" oninput="clReport.tech=this.value;updateClHeader();"></div>
      <div class="cl-field" style="max-width:100px;"><label>Tonnage</label><input class="cl-input" id="cl_tonnage" value="${clReport.tonnage||''}" placeholder="3.5" oninput="clReport.tonnage=this.value;"></div>
    </div>
    <div class="cl-row">
      <div class="cl-field"><label>Fuel Type</label>
        <div class="cl-toggle-row">
          <div class="cl-toggle ${clReport.fuel==='Gas'?'sel':''}" onclick="setFuel('Gas')">Gas</div>
          <div class="cl-toggle ${clReport.fuel==='Electric'?'sel':''}" onclick="setFuel('Electric')">Electric</div>
        </div>
      </div>
      <div class="cl-field"><label>Filter</label>
        <div class="cl-toggle-row">
          <div class="cl-toggle ${clReport.filter==='Clean'?'sel':''}" onclick="setFilter('Clean')">Clean</div>
          <div class="cl-toggle ${clReport.filter==='Dirty'?'sel':''}" onclick="setFilter('Dirty')">Dirty</div>
        </div>
      </div>
    </div>
  </div>`;

  // checklist sections
  CL_SECTIONS.forEach(sec=>{
    html+=`<div class="cl-section"><div class="cl-section-header">${sec.title}</div>`;
    sec.items.forEach(item=>{
      const key=item.replace(/\s+/g,'_');
      const val=clReport.checks[key]||'';
    html+=`<div class="cl-item">
        <div class="cl-item-name">${item}</div>
        <div class="cl-btns">
          <button class="cl-btn good-idle ${val==='good'?'sel-good':''}" onclick="setCheck('${key}','good')"><span class="btn-icon">✓</span><span class="btn-lbl">Good</span></button>
          <button class="cl-btn caution-idle ${val==='caution'?'sel-caution':''}" onclick="setCheck('${key}','caution')"><span class="btn-icon">!</span><span class="btn-lbl">Caution</span></button>
          <button class="cl-btn bad-idle ${val==='bad'?'sel-bad':''}" onclick="setCheck('${key}','bad')"><span class="btn-icon">✕</span><span class="btn-lbl">Bad</span></button>
          <button class="cl-btn na-idle ${val==='na'?'sel-na':''}" onclick="setCheck('${key}','na')"><span class="btn-icon">—</span><span class="btn-lbl">N/A</span></button>
        </div>
      </div>`;
    });
    html+='</div>';
  });

  // notes & photos
  const photos=clReport.photos||[];
  html+=`<div class="cl-extras">
    <div class="cl-extras-title">Notes</div>
    <textarea class="cl-textarea" id="clNotesInput" placeholder="Write any notes about this job..." oninput="clReport.notes=this.value">${clReport.notes||''}</textarea>

  </div>
  <div class="cl-extras">
    <div class="cl-extras-title">Job Photos</div>
    <div class="cl-photo-upload" id="clPhotoUploadBtn" style="cursor:pointer;">
      <div style="font-size:28px;margin-bottom:4px;">📷</div>
      <div style="font-size:13px;font-weight:600;color:var(--muted);">Tap to add photos</div>
      <div style="font-size:11px;color:var(--muted);margin-top:2px;">Take a photo or choose from library</div>
    </div>
    <input type="file" id="clPhotoInput" accept="image/*" multiple style="display:none;">
    <div class="cl-photos-preview" id="clPhotosPreview">
      ${photos.map((p,i)=>`<div class="cl-photo-wrap"><img class="cl-photo-img" src="${p}" onclick="openLightboxArr(clReport.photos,${i})"><button class="cl-photo-del" onclick="removeClPhoto(${i})">✕</button></div>`).join('')}
    </div>
  </div>
  <button class="cl-save-btn" onclick="saveReport()">💾 SAVE REPORT</button>
  <div style="height:20px;"></div>`;

document.getElementById(‘clBody’).innerHTML=html;

// Re-attach photo input listener every time checklist renders
const clPhotoBtn = document.getElementById(‘clPhotoUploadBtn’);
const clPhotoInput = document.getElementById(‘clPhotoInput’);
clPhotoBtn.addEventListener(‘click’, () => clPhotoInput.click());
clPhotoInput.addEventListener(‘change’, function(){
Array.from(this.files).forEach(f=>{
compressPhoto(f, compressed => {
clReport.photos=clReport.photos||[];
clReport.photos.push(compressed);
const prev=document.getElementById(‘clPhotosPreview’);
const i=clReport.photos.length-1;
const wrap=document.createElement(‘div’);
wrap.className=‘cl-photo-wrap’;
wrap.innerHTML=`<img class="cl-photo-img" src="${compressed}" onclick="openLightboxArr(clReport.photos,${i})"><button class="cl-photo-del" onclick="removeClPhoto(${i})">✕</button>`;
prev.appendChild(wrap);
});
});
this.value=’’;
});
}

function updateClHeader(){
document.getElementById(‘clCustomer’).textContent=clReport.customer||’—’;
document.getElementById(‘clAddr’).textContent=clReport.address||’—’;
document.getElementById(‘clTech’).textContent=clReport.tech||’—’;
}
function setCheck(key,val){
clReport.checks=clReport.checks||{};
clReport.checks[key]=clReport.checks[key]===val?’’:val;
const good=Object.values(clReport.checks).filter(v=>v===‘good’).length;
const caution=Object.values(clReport.checks).filter(v=>v===‘caution’).length;
const bad=Object.values(clReport.checks).filter(v=>v===‘bad’).length;
document.querySelectorAll(’.cl-sum-num.g’).forEach(el=>el.textContent=good);
document.querySelectorAll(’.cl-sum-num.c’).forEach(el=>el.textContent=caution);
document.querySelectorAll(’.cl-sum-num.b’).forEach(el=>el.textContent=bad);
document.querySelectorAll(’.cl-item’).forEach(row=>{
const name=row.querySelector(’.cl-item-name’).textContent;
const k=name.replace(/\s+/g,’_’);
if(k!==key)return;
const btns=row.querySelectorAll(’.cl-btn’);
const v=clReport.checks[k]||’’;
btns[0].className=‘cl-btn good-idle’+(v===‘good’?’ sel-good’:’’);
btns[1].className=‘cl-btn caution-idle’+(v===‘caution’?’ sel-caution’:’’);
btns[2].className=‘cl-btn bad-idle’+(v===‘bad’?’ sel-bad’:’’);
btns[3].className=‘cl-btn na-idle’+(v===‘na’?’ sel-na’:’’);
});
}
function setFuel(val){
clReport.fuel=val;
document.querySelectorAll(’.cl-toggle’).forEach(t=>{
if(t.textContent===‘Gas’||t.textContent===‘Electric’) t.classList.toggle(‘sel’,t.textContent===val);
});
}
function setFilter(val){
clReport.filter=val;
document.querySelectorAll(’.cl-toggle’).forEach(t=>{
if(t.textContent===‘Clean’||t.textContent===‘Dirty’) t.classList.toggle(‘sel’,t.textContent===val);
});
}

// cl photos handled inside renderChecklist()
function removeClPhoto(i){clReport.photos.splice(i,1);renderChecklist();}

function saveReport(){
clReport.notes=document.getElementById(‘clBody’).querySelector(’.cl-textarea’)?.value||clReport.notes||’’;
if(currentReportId){
const idx=hvacReports.findIndex(r=>r.id===currentReportId);
if(idx>=0)hvacReports[idx]=clReport;
} else {
currentReportId=clReport.id;
hvacReports.push(clReport);
}
try {
saveHvac();
const btn=document.querySelector(’.cl-save-btn’);
btn.textContent=‘✅ Saved!’;btn.style.background=‘var(–green)’;
setTimeout(()=>{btn.textContent=‘💾 SAVE REPORT’;btn.style.background=’’;},2000);
} catch(e) {
alert(‘Storage full — try removing some photos and save again. Photos are large files.’);
}
}

// ── SHARE ──
document.getElementById(‘clShareBtn’).addEventListener(‘click’,()=>{
const r=clReport;
let txt=`SUPERIOR SERVICES\nHVAC Maintenance Report\n`;
txt+=`${'─'.repeat(32)}\n`;
txt+=`Date: ${r.date||'—'}   Tech: ${r.tech||'—'}\n`;
txt+=`Customer: ${r.customer||'—'}\n`;
txt+=`Address: ${r.address||'—'}\n`;
if(r.unit) txt+=`Unit #: ${r.unit}\n`;
if(r.tonnage) txt+=`Tonnage: ${r.tonnage}\n`;
if(r.fuel) txt+=`Fuel: ${r.fuel}\n`;
if(r.filter) txt+=`Filter: ${r.filter}\n`;
txt+=`${'─'.repeat(32)}\n\nCHECKLIST:\n`;
CL_SECTIONS.forEach(sec=>{
const checked=sec.items.filter(item=>r.checks&&r.checks[item.replace(/\s+/g,’*’)]);
if(!checked.length)return;
txt+=`\n${sec.title.toUpperCase()}\n`;
sec.items.forEach(item=>{
const k=item.replace(/\s+/g,’*’);
const v=r.checks&&r.checks[k];
if(!v)return;
const icon=v===‘good’?‘✓ GOOD’:v===‘caution’?’! CAUTION’:v===‘na’?’— N/A’:‘✕ ISSUE’;
txt+=`  ${icon}: ${item}\n`;
});
});
if(r.notes){txt+=`\n${'─'.repeat(32)}\nNOTES:\n${r.notes}\n`;}
txt+=`\n${'─'.repeat(32)}\nSuperior Services · (985) 781-0418`;
document.getElementById(‘shareText’).textContent=txt;
document.getElementById(‘shareOverlay’).classList.add(‘open’);
});
document.getElementById(‘shareCloseBtn’).addEventListener(‘click’,()=>document.getElementById(‘shareOverlay’).classList.remove(‘open’));
document.getElementById(‘shareCopyBtn’).addEventListener(‘click’,()=>{
const txt=document.getElementById(‘shareText’).textContent;
if(navigator.clipboard){navigator.clipboard.writeText(txt).then(()=>{
const btn=document.getElementById(‘shareCopyBtn’);btn.textContent=‘✅ Copied!’;
setTimeout(()=>btn.textContent=‘📋 Copy Report’,2000);
});}else{
const ta=document.createElement(‘textarea’);ta.value=txt;document.body.appendChild(ta);ta.select();document.execCommand(‘copy’);document.body.removeChild(ta);
const btn=document.getElementById(‘shareCopyBtn’);btn.textContent=‘✅ Copied!’;setTimeout(()=>btn.textContent=‘📋 Copy Report’,2000);
}
});

// ── LIGHTBOX ──
function openLightbox(source,id,index){
let photos=[];
if(source===‘job’){const j=jobs.find(j=>j.id===id);photos=j?j.photos||[]:[]; }
openLightboxArr(photos,index);
}
function openLightboxArr(photos,index){
lightboxPhotos=photos;lightboxIndex=index;
document.getElementById(‘lightboxImg’).src=photos[index];
document.getElementById(‘lightboxCounter’).textContent=`${index+1} of ${photos.length}`;
document.getElementById(‘lightbox’).classList.add(‘open’);
}
document.getElementById(‘lightboxClose’).addEventListener(‘click’,()=>document.getElementById(‘lightbox’).classList.remove(‘open’));
document.getElementById(‘lightbox’).addEventListener(‘click’,e=>{if(e.target===document.getElementById(‘lightbox’))document.getElementById(‘lightbox’).classList.remove(‘open’);});
document.getElementById(‘lightboxPrev’).addEventListener(‘click’,()=>{lightboxIndex=(lightboxIndex-1+lightboxPhotos.length)%lightboxPhotos.length;document.getElementById(‘lightboxImg’).src=lightboxPhotos[lightboxIndex];document.getElementById(‘lightboxCounter’).textContent=`${lightboxIndex+1} of ${lightboxPhotos.length}`;});
document.getElementById(‘lightboxNext’).addEventListener(‘click’,()=>{lightboxIndex=(lightboxIndex+1)%lightboxPhotos.length;document.getElementById(‘lightboxImg’).src=lightboxPhotos[lightboxIndex];document.getElementById(‘lightboxCounter’).textContent=`${lightboxIndex+1} of ${lightboxPhotos.length}`;});



